{
    "name": "@dh253/nds",
    "version": "0.1.0-alpha",
    "description": "Neuroinclusive, Accessible, Sustainable Design System",
    "repository": {
        "type": "git",
        "url": "https://github.com/dustinheisey/nurtur-design-system.git"
    },
    "scripts": {
        "i": "rm -rf node_modules && npm install",
        "release": "release-please",
        "concat-css": "concat -o index.css styles/**/*.css",
        "minify-css": "cleancss -o dist/index.min.css index.css",
        "build-css": "npm run concat-css && npm run minify-css",
        "watch-css": "watch -p 'styles/**/*.css' -c 'npm run build-css'",
        "concat-js": "concat -o index.js scripts/*.js",
        "minify-js": "terser index.js -o dist/index.min.js",
        "build-js": "npm run concat-js && npm run minify-js",
        "watch-js": "watch -p 'scripts/*.js' -c 'npm run build-js'"
    },
    "author": {
        "name": "Dustin Heisey"
    },
    "devDependencies": {
        "@commitlint/cli": "^19.3.0",
        "@commitlint/config-conventional": "^19.2.2",
        "clean-css": "^5.3.3",
        "clean-css-cli": "^5.6.3",
        "concat-cli": "^4.0.0",
        "husky": "^9.0.11",
        "release-please": "^16.12.0",
        "terser": "^5.31.1",
        "watch-cli": "^0.2.3"
    }
}
